{
  "name": "recruter-tech",
  "version": "1.3.0",
  "description": "Sistema de Entrevistas Técnicas - Desktop App",
  "main": "electron/main.js",
  "type": "module",
  "author": "Recruter Tech Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "electron .",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm install --production",
    "build:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false && npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "build:all": "set CSC_IDENTITY_AUTO_DISCOVERY=false && npm run build && electron-builder --win --linux",
    "postinstall": "cd frontend && npm install && cd ../backend && npm install"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "electron-store": "^11.0.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-icon-builder": "^2.0.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.recrutertech.app",
    "productName": "Recruter Tech",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!data/**/*",
          "!uploads/**/*",
          "!.env",
          "!.env.example",
          "!.gitignore",
          "!Dockerfile",
          "!docker-compose.yml"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": true
    }
  }
}
